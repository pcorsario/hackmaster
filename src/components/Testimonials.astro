---
interface Testimonial {
  quote: string;
  author: string;
  role?: string;
  avatar?: string;
}

import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  testimonials?: Testimonial[];
}

const { eyebrow, title, testimonials } = Astro.props;

let items: Testimonial[] = testimonials ?? [];

if (!testimonials) {
  const entries = await getCollection("testimonials");
  items =
    entries.length === 1 && Array.isArray(entries[0].data)
      ? (entries[0].data as Testimonial[])
      : entries.map((e) => e.data as Testimonial);
}
---

<section class="py-16 md:py-24 text-center">
  <div class="max-w-7xl mx-auto px-4">
    <header class="mb-12">
      {
        title && (
          <h2 class="text-4xl md:text-5xl font-black uppercase text-[#34077D] tracking-tighter mb-4">
            {title}
          </h2>
        )
      }
      {
        eyebrow && (
          <p class="text-lg md:text-xl text-gray-700 font-medium">{eyebrow}</p>
        )
      }
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 relative">
      {
        items.map((t, i) => (
          <article class="relative w-full aspect-[9/16] rounded-3xl overflow-hidden shadow-2xl bg-black group transform transition-transform duration-300 hover:-translate-y-2">
            {t.avatar && (
              <img
                src={t.avatar}
                alt={`Testimonio de ${t.author}`}
                class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity duration-300"
              />
            )}

            {/* Top overlay (Logo / Branding) */}
            <div class="absolute top-4 left-0 w-full flex justify-center z-20">
              <div class="bg-white/90 backdrop-blur-sm px-4 py-1.5 rounded-full shadow-md flex items-center gap-2">
                <img src="/logohm1.png" alt="Hack Master" class="h-6 w-auto" />
                <span class="text-xs font-bold text-[#1b1e4c] tracking-tight uppercase">
                  Hack Master
                </span>
              </div>
            </div>

            {/* Social UI Overlay */}
            <div class="absolute inset-0 flex flex-col justify-end p-4 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10">
              {/* Right sidebar icons */}
              <div class="absolute right-4 bottom-28 flex flex-col gap-6 items-center">
                <div class="flex flex-col items-center gap-1 group/icon cursor-pointer">
                  <Icon
                    name="tabler:heart-filled"
                    size={28}
                    class="text-white drop-shadow-md group-hover/icon:text-red-500 transition-colors"
                  />
                  <span class="text-white text-xs font-bold drop-shadow-md">
                    {(Math.random() * 100 + 50).toFixed(0)}
                  </span>
                </div>
                <div class="flex flex-col items-center gap-1 group/icon cursor-pointer">
                  <Icon
                    name="tabler:message-circle"
                    size={28}
                    class="text-white drop-shadow-md"
                  />
                  <span class="text-white text-xs font-bold drop-shadow-md">
                    {(Math.random() * 20 + 5).toFixed(0)}
                  </span>
                </div>
                <div class="flex flex-col items-center gap-1 group/icon cursor-pointer">
                  <Icon
                    name="tabler:send"
                    size={28}
                    class="text-white drop-shadow-md"
                  />
                </div>
              </div>

              {/* Bottom Content */}
              <div class="w-[85%] text-left text-white drop-shadow-lg mb-4">
                <h3 class="text-lg font-bold mb-1 flex items-center gap-2">
                  {t.author}
                  <Icon
                    name="tabler:rosette-discount-check-filled"
                    size={18}
                    class="text-blue-400"
                  />
                </h3>
                <p class="text-sm line-clamp-2 leading-tight opacity-90">
                  {t.quote}
                </p>
              </div>

              {/* Progress Bar & Play Icon */}
              <div class="flex items-center gap-2 w-full mt-2">
                <Icon
                  name="tabler:player-play-filled"
                  size={12}
                  class="text-white"
                />
                <div class="flex-1 h-1 bg-white/30 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-white/90 rounded-full"
                    style={`width: ${(Math.random() * 40 + 30).toFixed(0)}%`}
                  />
                </div>
                <span class="text-[10px] text-white font-medium">0:00</span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
