---
import { Icon } from "astro-icon/components";
---

<section class="space-y-10 py-12">
  <header class="space-y-4 text-center max-w-4xl mx-auto">
    <h2
      class="text-3xl sm:text-4xl lg:text-5xl font-black uppercase text-ink m-0 leading-tight"
      style="color: #34077D;"
    >
      MÓDULOS
    </h2>
  </header>

  <div class="grid gap-8 md:grid-cols-2 max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Razonamiento -->
    <div
      class="rounded-2xl overflow-hidden border border-border bg-surface shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col group"
    >
      <div class="aspect-video relative overflow-hidden bg-muted/10">
        <img
          src="/razonamiento.webp"
          alt="Módulo de Razonamiento"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
        />
      </div>
      <div class="p-8 flex-1 flex flex-col">
        <div class="flex items-center gap-4 mb-5">
          <div
            class="p-3 rounded-2xl bg-[color-mix(in_oklab,currentColor_8%,transparent)] text-[#11bae8] group-hover:scale-110 transition-transform"
          >
            <Icon name="tabler:brain" class="w-8 h-8" />
          </div>
          <h3 class="text-2xl font-bold tracking-tight text-ink m-0">
            1. Razonamiento
          </h3>
        </div>
        <p class="text-ink text-base leading-relaxed m-0 font-semibold mb-3">
          Verbal, Numérico, lógico, atención y concentración.
        </p>
        <p class="text-muted text-base leading-relaxed m-0">
          Desarrollamos habilidades clave para resolver preguntas tipo examen de
          forma rápida y efectiva.
        </p>
      </div>
    </div>

    <!-- Conocimiento -->
    <div
      class="rounded-2xl overflow-hidden border border-border bg-surface shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col group"
    >
      <div class="aspect-video relative overflow-hidden bg-muted/10">
        <img
          src="/conocimiento.avif"
          alt="Módulo de Conocimiento"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out"
        />
      </div>
      <div class="p-8 flex-1 flex flex-col">
        <div class="flex items-center gap-4 mb-5">
          <div
            class="p-3 rounded-2xl bg-[color-mix(in_oklab,currentColor_8%,transparent)] text-[#11bae8] group-hover:scale-110 transition-transform"
          >
            <Icon name="tabler:atom" class="w-8 h-8" />
          </div>
          <h3 class="text-2xl font-bold tracking-tight text-ink m-0">
            2. Conocimiento
          </h3>
        </div>
        <p class="text-ink text-base leading-relaxed m-0 font-semibold mb-3">
          Matemática, física, química, biología y anatomía.
        </p>
        <p class="text-muted text-base leading-relaxed m-0">
          Refuerzo académico en las áreas fundamentales que evalúan las
          universidades.
        </p>
      </div>
    </div>
  </div>
</section>
