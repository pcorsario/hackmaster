---
import { Icon } from 'astro-icon/components';

interface Value {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  title?: string;
  copy?: string;
  values?: Value[];
}

const {
  eyebrow,
  title = 'Values & philosophy',
  copy,
  values = [],
} = Astro.props as Props;
---

<section class="space-y-10 py-8">
  <header class="space-y-4 text-center max-w-4xl mx-auto">
    {eyebrow && <p class="eyebrow m-0 text-muted" style="letter-spacing: 0.1em; font-size: 0.9rem; text-transform: none;">{eyebrow}</p>}
    {title && <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black uppercase text-ink m-0 leading-tight" style="color: #11bae8;">{title}</h2>}
    {copy && <p class="text-muted m-0 text-base md:text-lg">{copy}</p>}
  </header>

  {values.length > 0 && (
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {values.map((item) => (
        <div class="flex items-start gap-4 rounded-xl border border-border bg-surface px-6 py-8 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 relative overflow-hidden group">
          {item.icon && (
            <div class="flex-shrink-0 p-3 rounded-2xl bg-[color-mix(in_oklab,currentColor_8%,transparent)] text-ink group-hover:text-[#b91c1c] transition-colors">
              <Icon name={item.icon} class="w-10 h-10" />
            </div>
          )}
          <div class="flex-1">
            <h3 class="text-lg font-bold tracking-tight text-ink m-0 transition-colors">{item.title}</h3>
            <p class="text-muted text-sm leading-relaxed m-0 mt-2">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  )}
</section>
